{
  "name": "supabase-sync",
  "version": "0.1.0",
  "description": "Type-safe TanStack DB collections and TanStack Query options for Supabase tables, views, and RPC functions",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm test && pnpm build",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "keywords": [
    "supabase",
    "tanstack",
    "tanstack-db",
    "tanstack-query",
    "collections",
    "sync",
    "type-safe",
    "react",
    "postgrest"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/thebigthing313/supabase-sync.git"
  },
  "sideEffects": false,
  "packageManager": "pnpm@10.13.1",
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@supabase/supabase-js": "^2.102.0",
    "@tanstack/db": "^0.6.2",
    "@tanstack/query-core": "^5.96.2",
    "@tanstack/query-db-collection": "^1.0.33",
    "@types/node": "^25.5.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2",
    "zod": "^4.3.6"
  },
  "dependencies": {
    "@standard-schema/spec": "^1.1.0"
  },
  "peerDependencies": {
    "@supabase/supabase-js": "^2.0.0",
    "@tanstack/db": ">=0.6.0",
    "@tanstack/query-core": ">=5.0.0",
    "@tanstack/query-db-collection": ">=1.0.0"
  }
}
